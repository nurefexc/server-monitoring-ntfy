# ntfy notification settings
ntfy:
  url: "https://ntfy.sh/your_unique_topic" # Replace with your own!
  # token: "tk_..." # If you use authentication
  priority: "3"
  tags: "bar_chart"

# Alert thresholds
limits:
  temp: 
    warning: 75
    critical: 85
  disk: 
    warning: 85
    critical: 95
  ram: 
    warning: 80
    critical: 90
  net_mbps: 100   # Network traffic limit (Mbps)
  swap: 80        # Swap usage limit (%)
  inode: 90       # Inode usage limit (%)

# General monitoring settings
monitoring:
  hostname: "MyServer"
  timezone: "UTC"
  daily_time: "08:00"      # When to send daily summary
  check_interval: 60       # Frequency of checks (seconds)
  quiet_hours: "23:00-06:00" # Only critical alerts during this period
  heartbeat_file: "/tmp/heartbeat" # Docker healthcheck file path

# Docker specific settings
docker:
  auto_restart: true    # Try to restart if a container exits with error
  monitor_health: true  # Monitor Docker Healthcheck statuses (unhealthy)

# External URL/Service checks
services:
  - name: "Google"
    url: "https://www.google.com"
    expected_status: 200
  - name: "My Website"
    url: "https://example.com"
    check_ssl: true
    ssl_days_before: 7

# Log file monitoring
# The application watches these files for keywords/patterns.
# Note: On Debian 12+, rsyslog is not installed by default. 
# You might need to install it (apt install rsyslog) or monitor other log files.
logs:
  watch_files:
    - path: "/var/log/auth.log" # SSH logins
      patterns:
        - name: "SSH Login"
          regex: "Accepted (password|publickey) for .* from .*"
          priority: "4"
          tags: "key,lock"
    - path: "/var/log/syslog" # System logs (requires rsyslog)
      patterns:
        - name: "System Error"
          regex: ".*(ERROR|FATAL|CRITICAL).*"
          priority: "4"
          tags: "warning"
    - path: "/var/log/daemon.log" # Daemon specific logs
      patterns:
        - name: "Daemon Error"
          regex: ".*(error|fail).*"
          priority: "4"
          tags: "gear"
  
  # systemd journal monitoring (Alternative for systems without text log files)
  use_journal: true
  journal_patterns:
    - name: "SSH Login"
      regex: "Accepted (password|publickey) for .* from .*"
      priority: "4"
      tags: "key,lock"
    - name: "Kernel Error"
      regex: ".*(ERROR|FATAL|CRITICAL).*"
      priority: "4"
      tags: "warning"

# Backup monitoring
backups:
  - name: "Daily DB Backup"
    path: "/backups/db_latest.sql"
    max_age_hours: 25
